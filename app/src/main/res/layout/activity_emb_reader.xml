<?xml version="1.0" encoding="utf-8"?>
<!--
    EMBReaderActivity layout.
    fitsSystemWindows="true" on the root ensures the status bar and navigation bar
    are never obscured by content.
    emb_dialog_anchor is a 0dp FrameLayout whose parent is the RelativeLayout (a View),
    satisfying DragingPopup's requirement that anchor.getParent() be a View.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Chapter article WebView -->
    <WebView
        android:id="@+id/emb_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/emb_tts_bar"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="vertical" />

    <!-- TTS control bar pinned to bottom -->
    <LinearLayout
        android:id="@+id/emb_tts_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#CC1a1a1a"
        android:orientation="vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- Sentence progress -->
        <TextView
            android:id="@+id/emb_tv_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="2dp"
            android:singleLine="true"
            android:text="—"
            android:textColor="#99FFFFFF"
            android:textSize="11sp" />

        <!-- Controls: weightSum=2 keeps play/pause centred -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- LEFT: settings + prev, gravity=end -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end|center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/emb_btn_settings"
                    android:layout_width="@dimen/wh_tts_button"
                    android:layout_height="@dimen/wh_tts_button"
                    android:background="@drawable/bg_clickable"
                    android:contentDescription="Settings"
                    android:padding="5dp"
                    android:src="@drawable/glyphicons_137_cogwheel" />

                <ImageView
                    android:id="@+id/emb_btn_prev"
                    android:layout_width="@dimen/wh_tts_button"
                    android:layout_height="@dimen/wh_tts_button"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_clickable"
                    android:contentDescription="Previous sentence"
                    android:padding="4dp"
                    android:src="@drawable/glyphicons_173_rewind" />

            </LinearLayout>

            <!-- CENTRE: play/pause -->
            <ImageView
                android:id="@+id/emb_btn_play_pause"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="0"
                android:background="@drawable/bg_clickable"
                android:contentDescription="Play / Pause"
                android:padding="2dp"
                android:src="@drawable/glyphicons_175_play" />

            <!-- RIGHT: next + close, gravity=start -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start|center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/emb_btn_next"
                    android:layout_width="@dimen/wh_tts_button"
                    android:layout_height="@dimen/wh_tts_button"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_clickable"
                    android:contentDescription="Next sentence"
                    android:padding="4dp"
                    android:src="@drawable/glyphicons_177_forward" />

                <ImageView
                    android:id="@+id/emb_btn_close"
                    android:layout_width="@dimen/wh_tts_button"
                    android:layout_height="@dimen/wh_tts_button"
                    android:background="@drawable/bg_clickable"
                    android:contentDescription="Close"
                    android:padding="8dp"
                    android:src="@drawable/glyphicons_599_menu_close" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!--
        DragingPopup anchor — fills the screen so the popup can render inside it.
        Must be match_parent so the popup is visible when added via anchor.addView().
        Parent is the root RelativeLayout (a View) satisfying DragingPopup line 107.
        Initially GONE; DragingPopup.show() sets it to VISIBLE.
    -->
    <FrameLayout
        android:id="@+id/emb_dialog_anchor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

</RelativeLayout>
