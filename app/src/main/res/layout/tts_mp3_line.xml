<?xml version="1.0" encoding="utf-8"?>
<!--
    IN-APP TTS BAR — inflated by TTSControlsView.java only. Never used by RemoteViews.

    Layout approach: RelativeLayout for the controls row with ttsPlay set to
    centerInParent="true". The left and right groups are positioned toStartOf/toEndOf
    the play button and fill the remaining space. This guarantees the play button is
    exactly centred regardless of how many buttons are visible on each side.

    Must contain all IDs referenced by TTSControlsView.java:
      ttsBookMenu, ttsDialog, ttsPrev, ttsPlay, ttsNext,
      ttsPrevTrack, ttsNextTrack, ttsStop,
      trackName, layoutMp3, seekCurrent, seekMp3, seekMax
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#CC1a1a1a"
    android:clickable="true"
    android:orientation="vertical"
    android:padding="4dip">

    <!-- MP3 track name: hidden for books, shown for MP3 playlists -->
    <TextView
        android:id="@+id/trackName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="8dip"
        android:singleLine="true"
        android:text="1 Track.mp3"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- MP3 seek row: hidden for books -->
    <LinearLayout
        android:id="@+id/layoutMp3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/seekCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dip"
            android:layout_marginRight="4dip"
            android:text="00:10"
            android:textSize="@dimen/text_subtitle" />

        <SeekBar
            android:id="@+id/seekMp3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/seekMax"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dip"
            android:layout_marginRight="4dip"
            android:text="5:45"
            android:textSize="@dimen/text_subtitle" />
    </LinearLayout>

    <!-- Controls row. RelativeLayout pins ttsPlay to the centre; left and right groups
         are placed relative to it so centering holds regardless of visible button count. -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dip"
        android:paddingBottom="4dip">

        <!-- CENTRE: play/pause — anchored to parent centre first so side groups can
             reference it -->
        <ImageView
            android:id="@+id/ttsPlay"
            android:layout_width="@dimen/wh_tts_button"
            android:layout_height="@dimen/wh_tts_button"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_clickable"
            android:contentDescription="@string/play_pause"
            android:src="@drawable/glyphicons_175_play" />

        <!-- LEFT group: book-menu + settings + prev, gravity-centred in available space -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/ttsPlay"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ttsBookMenu"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/book_menu"
                android:padding="4dip"
                android:src="@drawable/glyphicons_588_book_open_text" />

            <ImageView
                android:id="@+id/ttsDialog"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:layout_marginLeft="6dp"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/settings"
                android:padding="2dip"
                android:src="@drawable/glyphicons_smileys_100_headphones" />

            <ImageView
                android:id="@+id/ttsPrev"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:layout_marginLeft="6dp"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/previous_page"
                android:padding="2dp"
                android:src="@drawable/glyphicons_173_rewind" />

        </LinearLayout>

        <!-- RIGHT group: next + prevTrack + nextTrack + stop -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/ttsPlay"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ttsNext"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/next_page"
                android:padding="2dp"
                android:src="@drawable/glyphicons_177_forward" />

            <!-- MP3 track nav buttons: GONE in book mode, visible in playlist mode -->
            <ImageView
                android:id="@+id/ttsPrevTrack"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:layout_marginLeft="6dip"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/next_track"
                android:padding="2dp"
                android:src="@drawable/glyphicons_172_skip_to_start" />

            <ImageView
                android:id="@+id/ttsNextTrack"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/previous_track"
                android:padding="2dp"
                android:src="@drawable/glyphicons_178_skip_to_end" />

            <ImageView
                android:id="@+id/ttsStop"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:layout_marginLeft="6dip"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/close"
                android:padding="8dp"
                android:src="@drawable/glyphicons_599_menu_close" />

        </LinearLayout>

    </RelativeLayout>

</LinearLayout>
