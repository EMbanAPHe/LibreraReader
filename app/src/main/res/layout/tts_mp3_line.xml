<?xml version="1.0" encoding="utf-8"?>
<!--
    IN-APP TTS BAR — inflated by TTSControlsView.java only. Never used by RemoteViews.

    Centering strategy: outer row is a weightSum=2 LinearLayout split into three sections:
        left group  (weight=1, gravity=end)   | ttsPlay (weight=0) | right group (weight=1, gravity=start)

    gravity=end on the LEFT group packs buttons toward the RIGHT (toward play button).
    gravity=start on the RIGHT group packs buttons toward the LEFT (toward play button).
    Both groups take equal weight so ttsPlay is always mathematically centred.
    GONE buttons on either side don't affect the other side's width because the groups
    always take exactly half the available space regardless of content.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#CC1a1a1a"
    android:clickable="true"
    android:orientation="vertical"
    android:padding="4dip">

    <!-- MP3 track name: hidden for books, shown for MP3 playlists -->
    <TextView
        android:id="@+id/trackName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="8dip"
        android:singleLine="true"
        android:text="1 Track.mp3"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- MP3 seek row: hidden for books -->
    <LinearLayout
        android:id="@+id/layoutMp3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/seekCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dip"
            android:layout_marginRight="4dip"
            android:text="00:10"
            android:textSize="@dimen/text_subtitle" />

        <SeekBar
            android:id="@+id/seekMp3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/seekMax"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dip"
            android:layout_marginRight="4dip"
            android:text="5:45"
            android:textSize="@dimen/text_subtitle" />
    </LinearLayout>

    <!-- Controls row: weightSum=2 ensures ttsPlay is always exactly centred -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="4dip"
        android:paddingTop="4dip"
        android:weightSum="2">

        <!-- LEFT group (weight=1, gravity=end): buttons pack toward the play button.
             Using gravity="end" means buttons are right-aligned within their half of
             the row, so they sit immediately to the left of ttsPlay with no gap. -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ttsBookMenu"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/book_menu"
                android:padding="4dip"
                android:src="@drawable/glyphicons_588_book_open_text" />

            <ImageView
                android:id="@+id/ttsDialog"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:layout_marginLeft="6dp"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/settings"
                android:padding="2dip"
                android:src="@drawable/glyphicons_smileys_100_headphones" />

            <ImageView
                android:id="@+id/ttsPrev"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:layout_marginLeft="6dp"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/previous_page"
                android:padding="2dp"
                android:src="@drawable/glyphicons_173_rewind" />

        </LinearLayout>

        <!-- CENTRE: play/pause — weight=0 so it takes only its natural size -->
        <ImageView
            android:id="@+id/ttsPlay"
            android:layout_width="@dimen/wh_tts_button"
            android:layout_height="@dimen/wh_tts_button"
            android:layout_gravity="center_vertical"
            android:layout_weight="0"
            android:background="@drawable/bg_clickable"
            android:contentDescription="@string/play_pause"
            android:src="@drawable/glyphicons_175_play" />

        <!-- RIGHT group (weight=1, gravity=start): buttons pack toward the play button.
             Using gravity="start" means buttons are left-aligned within their half,
             so they sit immediately to the right of ttsPlay with no gap. -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start|center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ttsNext"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:layout_marginLeft="6dp"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/next_page"
                android:padding="2dp"
                android:src="@drawable/glyphicons_177_forward" />

            <!-- Article reading mode button -->
            <ImageView
                android:id="@+id/ttsArticleView"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:layout_marginLeft="6dp"
                android:background="@drawable/bg_clickable"
                android:contentDescription="Article reading view"
                android:padding="4dp"
                android:src="@drawable/glyphicons_101_text" />

            <!-- Track nav: GONE in book mode, visible in MP3 playlist mode -->
            <ImageView
                android:id="@+id/ttsPrevTrack"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:layout_marginLeft="6dip"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/next_track"
                android:padding="2dp"
                android:src="@drawable/glyphicons_172_skip_to_start" />

            <ImageView
                android:id="@+id/ttsNextTrack"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/previous_track"
                android:padding="2dp"
                android:src="@drawable/glyphicons_178_skip_to_end" />

            <ImageView
                android:id="@+id/ttsStop"
                android:layout_width="@dimen/wh_tts_button"
                android:layout_height="@dimen/wh_tts_button"
                android:layout_marginLeft="6dip"
                android:background="@drawable/bg_clickable"
                android:contentDescription="@string/close"
                android:padding="8dp"
                android:src="@drawable/glyphicons_599_menu_close" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
